# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# PORT: The port the Express server listens on.
# Defaults to 3000 if not specified.
PORT=3000

# DEBUG: Enable verbose parser logging.
# Set to 'true' to see detailed scan chain reconstruction in the console.
DEBUG=false

# DISABLE_HMR: Disable Vite Hot Module Replacement.
# Set to 'true' if you experience flickering during rapid code edits.
DISABLE_HMR=false
